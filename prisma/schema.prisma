generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(cuid())
  name             String
  phone            String    @unique
  password         String?
  role             String    @default("user")
  userType         String    @default("acheteur")  // acheteur ou vendeur
  points           Int       @default(0)
  subscriptionTier String?
  subscriptionStart String?
  subscriptionEnd   String?
  createdAt        DateTime  @default(now())
  demands          Demand[]
  reveals          Reveal[]
}

model Demand {
  id          String    @id @default(cuid())
  title       String
  description String
  category    String    @default("Autre")
  budget      Int       @default(0)
  price       Int       @default(0)       // prix de vente pour les vendeurs
  quartier    String    @default("Dakar")
  urgency     String    @default("flexible")
  photo       String?
  whatsapp    String
  status      String    @default("active")
  annonceType String    @default("cherche")  // cherche ou vends
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  createdAt   DateTime  @default(now())
  reveals     Reveal[]
}

model Reveal {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  demandId  String
  demand    Demand   @relation(fields: [demandId], references: [id])
  createdAt DateTime @default(now())
}
