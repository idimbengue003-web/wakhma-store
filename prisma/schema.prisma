generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(cuid())
  name             String
  phone            String    @unique
  password         String?
  role             String    @default("user")
  userType         String    @default("acheteur")  // acheteur ou vendeur
  points           Int       @default(0)
  subscriptionTier String?
  subscriptionStart String?
  subscriptionEnd   String?
  salesCount       Int       @default(0)   // nombre de ventes réalisées
  purchasesCount   Int       @default(0)   // nombre d'achats réalisés
  createdAt        DateTime  @default(now())
  demands          Demand[]
  reveals          Reveal[]
  payments         Payment[]
}

model Demand {
  id          String    @id @default(cuid())
  title       String
  description String
  category    String    @default("Autre")
  budget      Int       @default(0)
  price       Int       @default(0)       // prix de vente pour les vendeurs
  quartier    String    @default("Dakar")
  urgency     String    @default("flexible")
  photo       String?
  whatsapp    String
  status      String    @default("active") // active, expired, sold
  annonceType String    @default("cherche")  // cherche ou vends
  expiresAt   DateTime?  // date d'expiration (7 jours après création)
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  createdAt   DateTime  @default(now())
  reveals     Reveal[]
}

model Reveal {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  demandId  String
  demand    Demand   @relation(fields: [demandId], references: [id])
  createdAt DateTime @default(now())
}

model Payment {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  type            String    // "points" ou "subscription"
  amount          Int       // montant en FCFA
  currency        String    @default("XOF")
  status          String    @default("pending") // pending, completed, failed, expired
  sessionToken    String?   // token SenePay checkout session
  orderReference  String?   @unique // référence unique de commande
  tierIndex       Int?      // index du pack points
  tierId          String?   // id de l'abonnement (diambar/king)
  provider        String    @default("senepay") // senepay, whatsapp
  providerTxId    String?   // ID transaction SenePay ou ID Wave
  netAmount       Int?      // montant net reçu après frais
  fees            Int?      // frais prélevés
  metadata        String?   // JSON libre

  // Champs WhatsApp Webhook Form
  senderPhone     String?   // numéro Wave de l'expéditeur
  senderName      String?   // nom de l'expéditeur
  transactionId   String?   // ID de transaction Wave (envoyé par l'utilisateur)
  proofImageUrl   String?   // URL ou base64 du screenshot de preuve
  adminNote       String?   // note de l'admin lors de la validation/refus

  createdAt       DateTime  @default(now())
  completedAt     DateTime?
}
